rules_version = '2';

// 設計の肝：
//  - イベントは誰でも読める（リンクを知っていれば見られる ＝ 調整さんと同じ公開モデル）
//  - 回答は「自分の uid の行」だけ作成・更新・削除できる → 他人の行は壊せない
//  - イベント本体（タイトル・時間帯）の変更はオーナーのみ
service cloud.firestore {
  match /databases/{database}/documents {

    match /events/{eventId} {
      allow read: if true;

      // 作成：認証済み・ownerUid が本人・フィールドセットと型・サイズを制限
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['title','settings','createdAt','ownerUid'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() >= 1
                    && request.resource.data.title.size() <= 200;

      // 設定変更はオーナーのみ・変更可能フィールドは settings のみ
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['settings']);

      // オーナー自身は削除可能
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;

      // 回答：docId が uid。自分の行だけ書ける。フィールド・型・サイズを制限。
      match /responses/{uid} {
        allow read: if true;
        allow create, update: if request.auth != null
                               && request.auth.uid == uid
                               && request.resource.data.keys().hasOnly(['name','color','slots','updatedAt'])
                               && request.resource.data.name is string
                               && request.resource.data.name.size() <= 100
                               && request.resource.data.color is string
                               && request.resource.data.color.matches('^#[0-9a-fA-F]{6}$')
                               && request.resource.data.slots is list
                               && request.resource.data.slots.size() <= 2000;
        allow delete: if request.auth != null
                       && request.auth.uid == uid;
      }
    }
  }
}
